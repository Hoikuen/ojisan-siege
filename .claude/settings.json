{
  "permissions": {
    "allow": [
      "Bash(npm run *)", "Bash(npm install)", "Bash(npm install *)", "Bash(npm ci)",
      "Bash(npx vite *)", "Bash(npx playwright *)", "Bash(node *)", "Bash(python3 *)",
      "Bash(git status*)", "Bash(git add *)", "Bash(git commit *)", "Bash(git diff *)",
      "Bash(git log *)", "Bash(git show *)", "Bash(git switch *)", "Bash(git branch *)",
      "Bash(git checkout *)", "Bash(git restore *)", "Bash(git stash*)", "Bash(git pull*)",
      "Bash(git push*)", "Bash(git fetch*)", "Bash(git remote *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowedDomains": ["registry.npmjs.org", "registry.yarnpkg.com", "github.com", "codeload.github.com", "objects.githubusercontent.com"],
    "filesystem": { "denyRead": ["~/Library/CloudStorage/Dropbox", "~/.ssh", "~/.aws", "~/.gnupg"] },
    "credentials": { "files": [ { "path": "~/.ssh", "mode": "deny" }, { "path": "~/.aws", "mode": "deny" }, { "path": "~/.gnupg", "mode": "deny" } ] }
  }
}
